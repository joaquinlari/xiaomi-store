@host = http://localhost:3000
@userId = 1
# usar id de un producto que exista
@productId = 1

### Ver carrito del usuario
GET {{host}}/carts/{{userId}}

### Agregar producto al carrito
POST {{host}}/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 2
}

### Cambiar cantidad del item
PATCH {{host}}/carts/{{userId}}/items/{{productId}}
Content-Type: application/json

{
  "quantity": 7
}

### Quitar item del carrito
DELETE {{host}}/carts/{{userId}}/items/{{productId}}

### Vaciar carrito completo
DELETE {{host}}/carts/{{userId}}/items

### Error: cantidad cero (400)
POST {{host}}/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 0
}

### Error: producto inexistente (404)
POST {{host}}/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": 999999,
  "quantity": 1
}

### Error: item no está (404)
PATCH {{host}}/carts/{{userId}}/items/999999
Content-Type: application/json

{
  "quantity": 3
}

### Error: borrar item inexistente
DELETE {{host}}/carts/{{userId}}/items/999999

### Error: userId inválido (400)
GET {{host}}/carts/abc
