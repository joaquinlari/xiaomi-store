@host = http://localhost:3000
@userId = 1
@productId = 5

GET {{host}}/products

POST {{host}}/products
Content-Type: application/json

{
  "category_id": null,
  "brand": "Xiaomi",
  "model": "Redmi Note 13",
  "description": "test",
  "price": 299,
  "stock": 50,
  "image_url": null
}

GET {{host}}/api/carts/{{userId}}

POST {{host}}/api/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 2
}

POST {{host}}/api/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 2
}

PATCH {{host}}/api/carts/{{userId}}/items/{{productId}}
Content-Type: application/json

{
  "quantity": 7
}

DELETE {{host}}/api/carts/{{userId}}/items/{{productId}}

DELETE {{host}}/api/carts/{{userId}}/items

POST {{host}}/api/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 0
}

POST {{host}}/api/carts/{{userId}}/items
Content-Type: application/json

{
  "productId": 999999,
  "quantity": 1
}

PATCH {{host}}/api/carts/{{userId}}/items/999999
